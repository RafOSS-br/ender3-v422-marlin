# Everything below is downloaded/generated by the build - reproducible, do not commit.
Marlin/            # Marlin Firmware clone
Configurations/    # Marlin Configurations clone (if any)
.pio_cache/        # PlatformIO cache (toolchain/platform)
.pio/              # PlatformIO build
output/            # firmware.bin and final configs from the local build
dist/              # release assets (CI)
*.bin
*.tgz
__pycache__/

# Local Claude Code settings
.claude/
